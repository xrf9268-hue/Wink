    "A password field or secure prompt is capturing keyboard input. Hyper and Fn-based shortcuts may not fire until it ends; other standard shortcuts keep working.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A password field or secure prompt is capturing keyboard input. Hyper and Fn-based shortcuts may not fire until it ends; other standard shortcuts keep working."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "密码框或安全输入提示正在捕获键盘输入。在其结束前，Hyper 和基于 Fn 的快捷键可能无法触发；其他标准快捷键仍可正常使用。"
          }
        }
      }
    },
