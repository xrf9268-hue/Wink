    "%@ permission was revoked. Wink needs this permission to work. Please re-enable it in System Settings > Privacy & Security > %@.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ permission was revoked. Wink needs this permission to work. Please re-enable it in System Settings > Privacy & Security > %@."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ 权限已被撤销。Wink 需要此权限才能正常工作。请在系统设置 > 隐私与安全性 > %@ 中重新启用。"
          }
        }
      }
    },
    "%@ versus the previous period.": {
